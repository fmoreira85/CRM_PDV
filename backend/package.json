{
  "name": "crm-pdv-backend",
  "version": "0.1.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "db:migrate": "mysql -u root -p < src\\config\\migrations.sql",
    "db:seed": "mysql -u root -p < src\\config\\seeders.sql",
    "db:reset": "npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.10.0"
  }
}
